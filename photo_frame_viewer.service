[Unit]
Description=Digital Photo Frame Viewer (Chromium Kiosk)
After=network.target photo_frame_server.service
Wants=photo_frame_server.service

[Service]
Type=simple
User=robert
TTYPath=/dev/tty1
ExecStart=/usr/bin/xinit /home/robert/digital_photo_frame/start_kiosk.sh -- -nocursor :0 vt1
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
